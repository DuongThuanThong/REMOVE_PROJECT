# --- FMS ENVIRONMENT VARIABLES EXAMPLE ---
# Copy file này thành file .env và điền giá trị thực tế của bạn

# SERVER CONFIG
SERVER_PORT=8080

# DATABASE CONFIG
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_POST=5432

REDIS_PORT=6379
# JWT SECURITY CONFIG
JWT_SECRET=your_secret_key_at_least_64_characters
JWT_EXPIRATION=900000